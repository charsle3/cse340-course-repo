<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

 <form action="/edit-project/<%= projectDetails.project_id %>" method="POST">
    <div class="form-group">
      <label for="title">Project Title</label>
      <input
        type="text"
        id="title"
        name="title"
        value="<%= projectDetails.title %>"
        maxlength="150"
        required
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        maxlength="500"
        required
      ><%= projectDetails.description %></textarea>
    </div>

    <div class="form-group">
      <label for="location">Location</label>
      <input
        type="text"
        id="location"
        name="location"
        value="<%= projectDetails.location %>"
        maxlength="150"
        required
      />
    </div>

    <div class="form-group">
      <label for="date">Date</label>
      <input
        type="date"
        id="date"
        name="date"
        required
        value="<%= projectDetails.date.toISOString().split('T')[0] %>"
      />
    </div>

    <div class="form-group">
        <select 
        name="organizationId" 
        id="organizationId"
        required>
            <% allOrganizations.forEach(organization => { %>
                <option value="<%= organization.organization_id %>"><%= organization.name %></option>
            <% }); %>
        </select>
    </div>

    <button type="submit">Update Project</button>
  </form>

</main>
<%- include('partials/footer') %>